# Copy to .env and adjust as needed. All services read plain environment
# variables; nothing is hard-coded. (docker-compose sets its own values.)

# --- Kafka / Redpanda ---
# Host-run binaries talk to the compose "OUTSIDE" listener on 19092.
# In-container services use redpanda:9092 (set by docker-compose).
KAFKA_BROKERS=localhost:19092

# --- Feed Adapter ---
HL_WS_URL=wss://api.hyperliquid.xyz/ws       # mainnet; testnet: wss://api.hyperliquid-testnet.xyz/ws
HL_COINS=BTC,ETH                              # comma-separated coins to subscribe
HL_PING_INTERVAL=20s                          # server closes idle conns after 60s
TRADES_TOPIC=trades

# --- Trade Ingestor ---
INGESTOR_GROUP=ingestor
TRADES_TOPIC=trades
NORMALIZED_TOPIC=trades.normalized
DEDUP_WINDOW=100000                           # number of recent trade_ids remembered for dedup

# --- Batch Publisher ---
PUBLISHER_GROUP=batch-publisher
NORMALIZED_TOPIC=trades.normalized
BATCHES_TOPIC=settlement_batches
BATCH_MAX_SIZE=50                             # flush when this many trades accumulate
BATCH_MAX_WAIT=10s                            # flush this long after the first trade in a batch

# --- Chain Submitter ---
SUBMITTER_GROUP=chain-submitter
BATCHES_TOPIC=settlement_batches
DEAD_LETTER_TOPIC=dead_letter
CHAIN_FAILURE_RATE=0.2                        # mock chain random failure probability [0,1]
CHAIN_MIN_DELAY=50ms                          # mock chain min latency
CHAIN_MAX_DELAY=500ms                         # mock chain max latency
SUBMIT_MAX_ATTEMPTS=4                         # attempts before dead-lettering
SUBMIT_BASE_BACKOFF=200ms                     # exponential backoff base

# --- tradegen (test harness) ---
TRADES_TOPIC=trades
GEN_RATE=20                                   # synthetic trades per second
GEN_COINS=BTC,ETH
GEN_COUNT=0                                    # 0 = run forever

# --- Logging ---
LOG_LEVEL=info                                # debug|info|warn|error
